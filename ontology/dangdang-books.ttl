category:01.03.52.00.00.00 a kg:NovelCategory ;
  rdfs:label "影视小说"@zh ;
  kg:broaderCategory category:01.03.00.00.00.00 .

category:01.03.50.00.00.00 a kg:NovelCategory ;
  rdfs:label "官场小说"@zh ;
