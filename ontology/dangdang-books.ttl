category:01.03.39.00.00.00 a kg:NovelCategory ;
  rdfs:label "惊悚/恐怖"@zh ;
  kg:broaderCategory category:01.03.00.00.00.00 .

category:01.03.51.00.00.00 a kg:NovelCategory ;
  rdfs:label "历史小说"@zh ;
