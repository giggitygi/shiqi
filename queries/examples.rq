PREFIX kg: <https://example.org/dangdang/kg/>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# 余华写过哪些书
SELECT ?book ?title ?price ?rating ?comments ?url WHERE {
  ?book a kg:Book ;
        kg:title ?title ;
        kg:authoredBy ?author .
  ?author rdfs:label ?authorLabel .
  OPTIONAL { ?book kg:price ?price . }
  OPTIONAL { ?book kg:ratingPercent ?rating . }
  OPTIONAL { ?book kg:commentsCount ?comments . }
  OPTIONAL { ?book kg:detailUrl ?url . }
  FILTER(CONTAINS(STR(?authorLabel), "余华"))
}
ORDER BY ?title
LIMIT 20

# 推荐几本中国当代小说
SELECT ?book ?title ?authorLabel ?rating ?comments ?url WHERE {
  ?book a kg:Book ;
        kg:title ?title ;
        kg:inCategory ?category .
  ?category rdfs:label ?categoryLabel .
  OPTIONAL { ?book kg:authoredBy/rdfs:label ?authorLabel . }
  OPTIONAL { ?book kg:ratingPercent ?rating . }
  OPTIONAL { ?book kg:commentsCount ?comments . }
  OPTIONAL { ?book kg:detailUrl ?url . }
  FILTER(CONTAINS(STR(?categoryLabel), "中国当代小说"))
}
ORDER BY DESC(?comments)
LIMIT 10

# 最便宜的中国当代小说是哪本书
SELECT ?book ?title ?price ?rating ?comments ?url WHERE {
  ?book a kg:Book ;
        kg:title ?title ;
        kg:price ?price ;
        kg:inCategory ?category .
  ?category rdfs:label ?categoryLabel .
  OPTIONAL { ?book kg:ratingPercent ?rating . }
  OPTIONAL { ?book kg:commentsCount ?comments . }
  OPTIONAL { ?book kg:detailUrl ?url . }
  FILTER(CONTAINS(STR(?categoryLabel), "中国当代小说"))
}
ORDER BY ASC(?price)
LIMIT 1
